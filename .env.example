# Copy this to .env for local dev (never commit .env to git)
# Set these same variables in Netlify → Site Settings → Environment Variables

# Your myshopify domain (no https://)
SHOPIFY_STORE_DOMAIN=thegrint.myshopify.com

# Shopify Admin API access token
# Admin → Settings → Apps → Develop apps → Create app → Configure Admin API scopes:
#   write_discounts, read_discounts
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Numeric ID of your "PRO 15% off" Price Rule (see setup steps below)
SHOPIFY_PRICE_RULE_ID=1234567890
